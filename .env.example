DATA_DIR=data
# Predefined repository documents grouped by logical collection.
DEMO_DATA_DIR=data/demo
# Index predefined demo documents once per application process.
AUTO_INDEX_DEMO_DOCUMENTS=true
CHUNK_SIZE=800
CHUNK_OVERLAP=150
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHROMA_PERSIST_DIR=.chroma
CHROMA_COLLECTION_NAME=minirag_documents
DEFAULT_RAG_COLLECTION=general
RAG_COLLECTIONS=general,project,technical,policies
RAG_ROUTING_MODE=deterministic
DEFAULT_QUERY_MODE=manual
RAG_RETRIEVAL_STRATEGY=single_collection
MULTIRAG_MAX_COLLECTIONS=3
MULTIRAG_TOP_K_PER_COLLECTION=3
MULTIRAG_GLOBAL_TOP_K=6
MULTIRAG_DEDUPLICATION_ENABLED=true
MULTIRAG_MIN_SELECTION_CONFIDENCE=0.60
AGENT_PLANNING_MODE=deterministic
AGENT_PLANNING_TEMPERATURE=0.0
AGENT_MAX_PLANNING_TOKENS=400
AGENT_MIN_PLANNING_CONFIDENCE=0.60
AGENT_MAX_STEPS=2
AGENT_PLANNING_FALLBACK_ENABLED=true
DEFAULT_TOP_K=4
MAX_RETRIEVAL_DISTANCE=1.2
LLM_PROVIDER=openai
LLM_MODEL=gpt-4.1-mini
OPENAI_API_KEY=
GEMINI_API_KEY=
UPLOAD_DIR=data/uploads
ANSWER_TEMPERATURE=0.2
MAX_ANSWER_TOKENS=500
LLM_REQUEST_TIMEOUT=30
MAX_CONTEXT_CHARACTERS=12000
MAX_UPLOAD_SIZE_MB=10
